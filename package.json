{
  "name": "oando-replication",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev --webpack",
    "dev:cad": "npm -w cad-suite run dev",
    "dev:all": "npx -y concurrently \"npm run dev\" \"npm run dev:cad\"",
    "dev:turbo": "next dev --turbo",
    "dev:webpack": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && wrangler dev",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:d1:schema:apply": "wrangler d1 execute oneandonly-backup-db --file cloudflare/d1/backup-schema.sql",
    "cf:cad:build": "npm -w cad-suite run cf:build",
    "cf:cad:preview": "npm -w cad-suite run cf:preview",
    "cf:cad:deploy": "npm -w cad-suite run cf:deploy",
    "vercel:preview": "vercel --yes",
    "release:gate": "npm run lint && npm -w cad-suite run lint && npm test && npm run build && npm -w cad-suite run build",
    "vercel:prod": "npm run release:gate && vercel --prod --yes",
    "lint": "npm run lint:source",
    "lint:source": "eslint src/app src/components src/lib --ext .js,.jsx,.ts,.tsx,.mjs,.cjs",
    "test": "vitest run",
    "test:planner": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cdn:sync": "node scripts/sync_r2_assets.mjs",
    "supabase:backup": "npx tsx scripts/backup_supabase.ts"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.102.1",
    "@tanstack/react-query": "^5.95.2",
    "braces": "^3.0.3",
    "clsx": "^2.1.1",
    "detect-touch-device": "^1.1.6",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.1.0",
    "gsap": "^3.14.2",
    "html2canvas": "^1.4.1",
    "immer": "^11.1.4",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.7.0",
    "next": "^16.2.3",
    "openai": "^6.33.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hotkeys-hook": "^5.2.4",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "swiper": "^12.1.3",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1027.0",
    "@axe-core/react": "^4.11.1",
    "@fancyapps/ui": "^6.1.13",
    "@opennextjs/cloudflare": "^1.18.1",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.28.0",
    "@types/fs-extra": "^11.0.4",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-reports": "^3.0.4",
    "@types/node": "^25",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.3",
    "autoprefixer": "^10.4.27",
    "axe-core": "^4.11.1",
    "axios": "^1.15.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.1",
    "eslint": "^10.1.0",
    "eslint-config-next": "^16.2.3",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-tailwindcss": "^4.0.0-beta.0",
    "fs-extra": "^11.3.4",
    "jsdom": "^27.0.1",
    "nprogress": "^0.2.0",
    "postcss": "^8.5.8",
    "postgres": "^3.4.9",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react-hot-toast": "^2.6.0",
    "tailwindcss": "^4.2.2",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.3",
    "whatwg-fetch": "^3.6.20",
    "wrangler": "^4.81.0"
  }
}

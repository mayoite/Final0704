{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "oneandonly-cad-suite",
  "compatibility_date": "2026-04-06",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "routes": [
    {
      "pattern": "cad.oando.co.in",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "oneandonly-cad-suite"
    }
  ],
  "r2_buckets": [
    {
      "binding": "NEXT_INC_CACHE_R2_BUCKET",
      "bucket_name": "oneandonly-cad-suite-opennext-cache"
    }
  ],
  "d1_databases": [
    {
      "binding": "CATALOG_BACKUP_D1",
      "database_name": "oneandonly-backup-db",
      "database_id": "8117f302-64e7-4f81-a0d4-cd37314263a9"
    }
  ],
  "images": {
    "binding": "IMAGES"
  },
  "vars": {
    "NEXT_PUBLIC_SITE_URL": "https://cad.oando.co.in",
    "SITE_URL": "https://cad.oando.co.in",
    "NEXT_PUBLIC_SUPABASE_URL": "https://erpweaiypimorcunaimz.supabase.co",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "sb_publishable_s-rFltnlTHSTmNtYQrdOyQ_Z2P13F0t",
    "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY": "sb_publishable_s-rFltnlTHSTmNtYQrdOyQ_Z2P13F0t",
    "SUPABASE_URL": "https://erpweaiypimorcunaimz.supabase.co",
    "OPENAI_MODEL": "gpt-5.4",
    "OPENROUTER_MODEL": "openrouter/free"
  }
}
